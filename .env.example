# Turso Database
VITE_TURSO_URL=libsql://your-db.turso.io
VITE_TURSO_TOKEN=your_turso_token

# Login/Auth (PBKDF2)
VITE_AUTH_USERNAME_SALT=your_username_salt
VITE_AUTH_USERNAME_HASH=your_username_pbkdf2_sha256_hex_hash
VITE_AUTH_PASSWORD_SALT=your_password_salt
VITE_AUTH_PASSWORD_HASH=your_password_pbkdf2_sha256_hex_hash
VITE_AUTH_ITERATIONS=210000

# Email Notifications (Resend - free at resend.com)
RESEND_API_KEY=re_your_resend_key

# Optional AI parser for messy bulk import lines (OpenRouter)
OPENROUTER_API_KEY=sk-or-v1_your_openrouter_key
OPENROUTER_MODEL=stepfun/step-3.5-flash:free

# Optional: protect the cron endpoint
CRON_SECRET=your_random_secret
